*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE/editor state
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local runtime logs and traces (sensitive execution data)
logs/
*.trace.jsonl
*.log
*.tmp

# Test reports and captures (can contain sensitive screenshots)
qa/test_reports/
qa/data/captures/
qa/**/*.png
qa/**/*.jpg
qa/**/*.jpeg

# Local app/runtime scripts (generated/temporary)
__copilot_*.py
*.cache
.pytest_cache/

# Data generated at runtime or for training (sensitive/large)
data/captures/
data/glove/
data/vision_dataset/cifar-10-python.tar.gz
data/vision_dataset/train/
data/vision_dataset/val/
data/vision_dataset/test/
data/vision_dataset/cifar-10-batches-py/

# Persistent memory/session data
memory/
.session/

# Downloaded/compiled model artifacts (large binary files)
models/**/*.gguf
models/**/*.bin
models/**/*.safetensors
models/**/*.onnx
models/**/*.pkl
ml/models/cnn_vision/
ml/models/bilstm_saved/
ml/models/distilbert_intent/
ml/models/distilbert_onnx/
