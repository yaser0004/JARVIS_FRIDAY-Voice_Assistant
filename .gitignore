ml/models/**/*.pkl

# Embedded repositories / submodules
openclaw/

# Environment-specific configuration
.env
.env.local
.env.*.local
config.local.yaml

# Reference-only material not required for runtime
REFERENCE_ONLY_FOLDER/

# OS-specific files
Thumbs.db
.DS_Store

